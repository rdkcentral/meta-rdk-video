+static void  print_hexdumpkey(const void *data, size_t size) {
+    const unsigned char *buf = (const unsigned char *)data;
+    size_t i, j;
+
+    for (i = 0; i < size; i += 16) {
+        // Print address offset
+        printf("%08lx  ", i);
+
+        // Print hexadecimal bytes
+        for (j = 0; j < 16; j++) {
+            if (i + j < size) {
+                printf("%02x ", buf[i + j]);
+            } else {
+                printf("   "); // Pad if less than 16 bytes in last row
+            }
+            if (j == 7) { // Add extra space after 8 bytes for readability
+                printf(" ");
+            }
+        }
+
+        // Print ASCII representation
+        printf(" |");
+        for (j = 0; j < 16; j++) {
+            if (i + j < size) {
+                printf("%c", isprint(buf[i + j]) ? buf[i + j] : '.');
+            } else {
+                printf(" ");
+            }
+        }
+        printf("|\n");
+    }
+}
